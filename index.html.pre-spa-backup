          li++;
          nextLine();
        }
      }
      type();
    }
    nextLine();
  })();

  /* ───────── Glyph-shuffle headline word ───────── */
  (function glyph(){
    var el = document.querySelector(".glyph-shuffle");
    if(!el) return;
    var text = el.getAttribute("data-text") || el.textContent;
    var glyphs = "▓▒░█ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789{}<>/=*_-";
    var perChar = 60, scrambleMs = 180, fps = 28;

    el.textContent = "";
    var chars = text.split("").map(function(ch){
      var s = document.createElement("span");
      s.className = "gs-char";
      s.textContent = " ";
      el.appendChild(s);
      return { el: s, ch: ch };
    });

    if(reduced){
      chars.forEach(function(c){ c.el.textContent = c.ch === " " ? " " : c.ch; });
      return;
    }

    var start = performance.now();
    var stopAt = perChar * text.length + scrambleMs + 80;
    function tick(now){
      var t = now - start;
      for(var i=0;i<chars.length;i++){
        var c = chars[i];
        var cs = i * perChar, ce = cs + scrambleMs;
        if(t < cs){
          c.el.textContent = " ";
          c.el.classList.remove("gs-flash");
        } else if(t < ce && c.ch !== " "){
          c.el.textContent = glyphs[(Math.random() * glyphs.length) | 0];
          c.el.classList.add("gs-flash");
        } else {
          c.el.textContent = c.ch === " " ? " " : c.ch;
          c.el.classList.remove("gs-flash");
        }
      }
      if(t < stopAt){
        setTimeout(function(){ requestAnimationFrame(tick); }, 1000 / fps);
      }
    }
    requestAnimationFrame(tick);
  })();

  /* ───────── Scroll-driven reveals ───────── */
  (function reveals(){
    var selector = ".reveal:not(.in), .principle:not(.in), .stack-cell:not(.in)";
    var vh = window.innerHeight;

    document.querySelectorAll(selector).forEach(function(el){
      var r = el.getBoundingClientRect();
      if(r.top < vh * 0.95 && r.bottom > 0){ el.classList.add("in"); }
    });

    if(reduced){
      document.querySelectorAll(selector).forEach(function(el){ el.classList.add("in"); });
      return;
    }

    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if(e.isIntersecting){ e.target.classList.add("in"); io.unobserve(e.target); }
      });
    }, { threshold: 0.12, rootMargin: "0px 0px -6% 0px" });
    document.querySelectorAll(selector).forEach(function(el){ io.observe(el); });
  })();

  /* ───────── Animated stat counters ───────── */
  (function counters(){
    document.querySelectorAll(".sn[data-count]").forEach(function(el){
      var end = parseInt(el.getAttribute("data-count"), 10) || 0;
      if(reduced){ el.textContent = end; return; }
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(!e.isIntersecting) return;
          var t0 = performance.now(), duration = 1200;
          function tick(now){
            var t = Math.min(1, (now - t0) / duration);
            var eased = 1 - Math.pow(1 - t, 3);
            el.textContent = Math.round(end * eased);
            if(t < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
          io.disconnect();
        });
      }, { threshold: 0.5 });
      io.observe(el);
    });
  })();

