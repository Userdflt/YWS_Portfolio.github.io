<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Young Woo Song — AI Specialist</title>
<meta name="description" content="Young Woo Song — AI Specialist at Ignite, Auckland. Building internal AI tools, multi-agent RAG systems, and AI governance for architecture and design teams." />
<meta name="author" content="Young Woo Song" />
<meta property="og:type" content="website" />
<meta property="og:title" content="Young Woo Song — AI Specialist" />
<meta property="og:description" content="AI Specialist at Ignite. Internal AI tools, multi-agent RAG, generative vision, and AI governance for architecture and design." />

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root{
    --bg: #05070a;
    --bg-deep: #03050a;
    --panel: rgba(255,255,255,0.025);
    --line: rgba(120,200,220,0.10);
    --line-strong: rgba(120,200,220,0.22);
    --grid: rgba(120,200,220,0.06);

    --ink: #d8e4e7;
    --ink-dim: rgba(216,228,231,0.55);
    --ink-faint: rgba(216,228,231,0.32);

    --accent: #5eead4;                     /* terminal teal */
    --accent-2: #7dd3fc;                   /* cyan */
    --accent-soft: rgba(94,234,212,0.16);
    --accent-glow: rgba(94,234,212,0.42);
    --warn: #fbbf24;
    --ok: #84cc16;

    --fs-mono: "JetBrains Mono", "IBM Plex Mono", "Geist Mono", ui-monospace, monospace;

    --u: 8px;
    --pad-x: clamp(20px, 4.5vw, 72px);
    --content-max: 1280px;
  }

  *,*::before,*::after{box-sizing:border-box}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--ink);font-family:var(--fs-mono);font-size:14px;line-height:1.6;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
  body{overflow-x:hidden;min-height:100vh;font-feature-settings:"calt","ss01","cv02"}
  a{color:inherit;text-decoration:none}
  ::selection{background:var(--accent-soft);color:#fff}
  /* No italics — anywhere */
  i,em,.italic,[data-italic]{font-style:normal !important}

  /* layout */
  .wrap{position:relative;z-index:1;max-width:var(--content-max);margin:0 auto;padding-left:var(--pad-x);padding-right:var(--pad-x)}

  /* utilities */
  .num{font-variant-numeric:tabular-nums}

  /* cosmic / techy background */
  #cosmic-stage{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;
    background:
      radial-gradient(80% 60% at 50% 0%, rgba(94,234,212,0.06), transparent 60%),
      radial-gradient(60% 40% at 80% 30%, rgba(125,211,252,0.05), transparent 60%),
      linear-gradient(180deg, #05080d 0%, var(--bg) 45%, var(--bg-deep) 100%)}
  #cosmic-canvas{position:absolute;inset:0;width:100%;height:100%;display:block;opacity:0.85}
  /* tech grid overlay */
  #cosmic-stage::before{content:"";position:absolute;inset:0;
    background-image:
      linear-gradient(to right, var(--grid) 1px, transparent 1px),
      linear-gradient(to bottom, var(--grid) 1px, transparent 1px);
    background-size: 80px 80px, 80px 80px;
    mask-image: radial-gradient(ellipse at 50% 30%, #000 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 30%, #000 0%, transparent 70%);
  }
  .scanline{position:absolute;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--accent),transparent);opacity:.18;pointer-events:none;animation:scan 7s linear infinite}
  @keyframes scan{0%{top:-2%}100%{top:102%}}
  .vignette{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%, transparent 55%, rgba(0,0,0,0.55) 100%);pointer-events:none}

  /* scroll progress bar */
  .scroll-progress{position:fixed;top:0;left:0;right:0;height:2px;z-index:60;background:transparent;pointer-events:none}
  .scroll-progress .bar{height:100%;background:linear-gradient(90deg, var(--accent), var(--accent-2));width:0%;box-shadow:0 0 18px var(--accent-glow)}

  /* nav */
  .nav{position:fixed;top:0;left:0;right:0;z-index:50;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);background:linear-gradient(180deg, rgba(5,7,10,0.78), rgba(5,7,10,0.0));border-bottom:1px solid var(--line)}
  .nav-inner{display:flex;align-items:center;justify-content:space-between;height:56px;max-width:var(--content-max);margin:0 auto;padding-left:var(--pad-x);padding-right:var(--pad-x)}
  .brand{display:flex;align-items:center;gap:10px;font-family:var(--fs-mono);font-size:12px;letter-spacing:0.06em;font-weight:500}
  .brand .dot{width:7px;height:7px;background:var(--accent);box-shadow:0 0 14px var(--accent-glow)}
  .nav-links{display:flex;gap:24px}
  .nav-links a{font-family:var(--fs-mono);font-size:11px;color:var(--ink-dim);letter-spacing:0.08em;text-transform:uppercase;transition:color .2s;position:relative}
  .nav-links a:hover{color:var(--ink)}
  .nav-links a::before{content:"./";color:var(--ink-faint);margin-right:2px;opacity:0;transition:opacity .2s}
  .nav-links a:hover::before{opacity:1}
  .nav-cta{font-family:var(--fs-mono);font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink);border:1px solid var(--line-strong);padding:7px 12px;transition:all .2s;display:inline-flex;gap:8px;align-items:center}
  .nav-cta::before{content:"";width:6px;height:6px;background:var(--accent);box-shadow:0 0 8px var(--accent-glow)}
  .nav-cta:hover{background:var(--accent-soft);border-color:var(--accent);color:var(--accent)}
  @media (max-width: 760px){.nav-links{display:none}}

  /* section frame */
  section{position:relative;padding-top:calc(var(--u) * 14);padding-bottom:calc(var(--u) * 14)}
  .section-tag{display:flex;align-items:center;gap:14px;color:var(--ink-faint);margin-bottom:calc(var(--u)*4);font-size:11px;letter-spacing:0.1em;text-transform:uppercase}
  .section-tag .rule{flex:1;height:1px;background:linear-gradient(90deg, var(--line-strong), transparent)}
  .section-tag .marker{color:var(--accent)}

  /* ─────────────── HERO ─────────────── */
  .hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding-top:80px;padding-bottom:80px}

  /* terminal boot panel sits above the headline */
  .boot{font-family:var(--fs-mono);font-size:11.5px;color:var(--ink-dim);margin-bottom:40px;max-width:680px;line-height:1.65;min-height:160px}
  .boot .line{display:block;white-space:pre-wrap}
  .boot .ok{color:var(--ok)}
  .boot .acc{color:var(--accent)}
  .boot .dim{color:var(--ink-faint)}

  .hero-meta{display:flex;align-items:center;gap:12px;color:var(--ink-faint);margin-bottom:28px}
  .status-pill{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--line-strong);padding:6px 12px;font-family:var(--fs-mono);font-size:11px;letter-spacing:0.04em;color:var(--ink-dim);background:rgba(255,255,255,0.02)}
  .status-pill .pulse{position:relative;width:6px;height:6px;background:var(--ok);box-shadow:0 0 12px rgba(132,204,22,0.7)}
  .status-pill .pulse::after{content:"";position:absolute;inset:-4px;border:1px solid rgba(132,204,22,0.5);animation:pulse 2.4s ease-out infinite}
  @keyframes pulse{0%{transform:scale(.4);opacity:1}100%{transform:scale(1.6);opacity:0}}

  .hero h1{font-family:var(--fs-mono);font-weight:500;font-size:clamp(40px, 8vw, 124px);line-height:0.96;letter-spacing:-0.04em;margin:0;color:var(--ink);text-transform:lowercase}
  .hero h1 .acc{color:var(--accent)}
  .hero h1 .glyph-shuffle{display:inline-block}
  .hero h1 .gs-char{display:inline-block;min-width:.55ch;text-align:center}
  .hero h1 .gs-flash{color:var(--accent);text-shadow:0 0 14px var(--accent-glow)}

  .hero-tag{margin-top:32px;font-size:14px;color:var(--ink-dim);max-width:64ch;line-height:1.65}
  .hero-tag .prompt{color:var(--accent);margin-right:8px}

  .hero-foot{display:flex;align-items:end;justify-content:flex-start;margin-top:56px;gap:48px;flex-wrap:wrap;border-top:1px solid var(--line);padding-top:24px}
  .hero-foot .col{display:flex;flex-direction:column;gap:6px;min-width:140px}
  .hero-foot .k{font-family:var(--fs-mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink-faint)}
  .hero-foot .v{font-family:var(--fs-mono);font-size:12.5px;color:var(--ink-dim)}
  .hero-foot .v a{position:relative;transition:color .2s}
  .hero-foot .v a:hover{color:var(--accent)}

  .scroll-cue{position:absolute;left:50%;transform:translateX(-50%);bottom:18px;display:flex;flex-direction:column;align-items:center;gap:8px;color:var(--ink-faint);font-family:var(--fs-mono);font-size:10px;letter-spacing:0.16em;text-transform:uppercase}
  .scroll-cue .line{width:1px;height:32px;background:linear-gradient(180deg, transparent, var(--accent));animation:scrollLine 2.2s ease-in-out infinite}
  @keyframes scrollLine{0%,100%{transform:scaleY(.6);opacity:.4}50%{transform:scaleY(1);opacity:1}}

  /* ─────────────── WORK ─────────────── */
  .work-list{display:flex;flex-direction:column;border-top:1px solid var(--line)}
  .work-row{position:relative;display:grid;grid-template-columns:48px 1fr auto auto;align-items:center;gap:24px;padding:calc(var(--u)*3.2) 0;border-bottom:1px solid var(--line);cursor:pointer;transition:padding .35s ease, background .35s ease}
  .work-row::before{content:"";position:absolute;left:0;top:0;width:2px;height:100%;background:var(--accent);transform:scaleY(0);transform-origin:center;transition:transform .35s ease}
  .work-row:hover{padding-left:18px;padding-right:8px;background:linear-gradient(90deg, rgba(94,234,212,0.04), transparent 70%)}
  .work-row:hover::before{transform:scaleY(1)}
  .work-row .idx{font-family:var(--fs-mono);font-size:11px;color:var(--ink-faint);letter-spacing:0.06em}
  .work-row:hover .idx{color:var(--accent)}
  .work-row .title-col{display:flex;flex-direction:column;gap:6px;min-width:0}
  .work-row .title{font-family:var(--fs-mono);font-weight:500;font-size:clamp(22px, 2.6vw, 34px);line-height:1.1;letter-spacing:-0.03em;color:var(--ink);text-transform:lowercase;transition:color .25s}
  .work-row:hover .title{color:var(--accent)}
  .work-row .blurb{font-size:12.5px;color:var(--ink-dim);max-width:72ch;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden}
  .work-row .blurb::before{content:"// ";color:var(--ink-faint)}
  .work-row .cat{font-family:var(--fs-mono);font-size:10.5px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-faint);white-space:nowrap}
  .work-row .arrow{width:30px;height:30px;border:1px solid var(--line-strong);display:flex;align-items:center;justify-content:center;color:var(--ink-dim);transition:all .25s;font-family:var(--fs-mono);font-size:14px}
  .work-row:hover .arrow{background:var(--accent);border-color:var(--accent);color:#04060a;transform:translate(2px,-2px)}
  @media (max-width: 640px){
    .work-row{grid-template-columns:36px 1fr auto;gap:14px}
    .work-row .cat{display:none}
  }

  /* hover preview thumbnail (follows cursor) */
  .work-preview{position:fixed;width:240px;height:160px;overflow:hidden;pointer-events:none;z-index:40;border:1px solid var(--accent);background:#06080d;opacity:0;transform:translate(-50%,-50%) scale(0.92);transition:opacity .2s, transform .35s cubic-bezier(.2,.8,.2,1);box-shadow:0 0 40px rgba(94,234,212,0.18)}
  .work-preview.show{opacity:1;transform:translate(-50%,-50%) scale(1)}
  .preview-inner{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:
    repeating-linear-gradient(0deg, rgba(94,234,212,0.05) 0 1px, transparent 1px 24px),
    repeating-linear-gradient(90deg, rgba(94,234,212,0.05) 0 1px, transparent 1px 24px),
    linear-gradient(135deg, rgba(94,234,212,0.10), rgba(0,0,0,0.6))}
  .preview-mark{font-family:var(--fs-mono);font-weight:500;font-size:42px;color:var(--accent);line-height:1;text-shadow:0 0 18px var(--accent-glow)}
  .preview-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .25s}
  .preview-img.loaded{opacity:1}
  .preview-scrim{position:absolute;inset:0;pointer-events:none;background:linear-gradient(180deg, rgba(4,6,10,0.35) 0%, transparent 32%, transparent 56%, rgba(4,6,10,0.85) 100%)}
  .preview-meta{position:absolute;left:10px;right:10px;bottom:8px;display:flex;justify-content:space-between;align-items:end;color:#fff;font-family:var(--fs-mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase}
  .preview-meta .pm-cat{color:var(--ink-dim)}
  .preview-meta .pm-tag{color:var(--accent)}
  .preview-frame{position:absolute;top:6px;left:6px;right:6px;display:flex;justify-content:space-between;color:var(--ink-faint);font-size:9px;letter-spacing:0.1em;text-transform:uppercase}

  /* ─────────────── APPROACH ─────────────── */
  .approach-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:48px;align-items:start}
  @media (max-width: 900px){.approach-grid{grid-template-columns:1fr}}
  .approach h2{font-family:var(--fs-mono);font-weight:500;font-size:clamp(28px, 4vw, 52px);line-height:1.05;letter-spacing:-0.03em;margin:0 0 16px;color:var(--ink);text-transform:lowercase}
  .approach h2 .acc{color:var(--accent)}
  .approach p{color:var(--ink-dim);font-size:13.5px;line-height:1.7;max-width:60ch;margin:0 0 18px}
  .approach p::before{content:"> ";color:var(--accent);opacity:.6}
  .principles{display:flex;flex-direction:column;gap:0}
  .principle{display:grid;grid-template-columns:48px 1fr;gap:16px;padding:18px 0;border-top:1px solid var(--line);position:relative}
  .principle:last-child{border-bottom:1px solid var(--line)}
  .principle::before{content:"";position:absolute;left:0;top:0;height:1px;width:0;background:var(--accent);transition:width .8s ease}
  .principle.in::before{width:48px}
  .principle .pn{font-family:var(--fs-mono);font-size:11px;color:var(--accent);letter-spacing:0.06em;padding-top:4px}
  .principle .pt{font-family:var(--fs-mono);font-weight:500;font-size:16px;line-height:1.3;color:var(--ink);margin-bottom:6px;text-transform:lowercase;letter-spacing:-0.01em}
  .principle .pd{font-size:13px;color:var(--ink-dim);line-height:1.6}

  /* ─────────────── STACK ─────────────── */
  .stack-grid{display:grid;grid-template-columns:repeat(4, 1fr);gap:1px;background:var(--line);border:1px solid var(--line)}
  @media (max-width: 900px){.stack-grid{grid-template-columns:repeat(2,1fr)}}
  @media (max-width: 540px){.stack-grid{grid-template-columns:1fr}}
  .stack-cell{background:var(--bg);padding:calc(var(--u)*3);min-height:200px;display:flex;flex-direction:column;gap:14px;transition:background .25s;position:relative}
  .stack-cell::before{content:"";position:absolute;top:0;left:0;width:0;height:1px;background:var(--accent);transition:width .6s ease}
  .stack-cell.in::before{width:100%}
  .stack-cell:hover{background:rgba(94,234,212,0.04)}
  .stack-cell .sh{font-family:var(--fs-mono);font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent)}
  .stack-cell .st{font-family:var(--fs-mono);font-weight:500;font-size:16px;line-height:1.2;color:var(--ink);text-transform:lowercase;letter-spacing:-0.01em}
  .stack-cell .stags{display:flex;flex-wrap:wrap;gap:6px;margin-top:auto}
  .stack-cell .tag{font-family:var(--fs-mono);font-size:11px;color:var(--ink-dim);padding:3px 9px;border:1px solid var(--line);background:rgba(255,255,255,0.015);transition:all .2s}
  .stack-cell .tag::before{content:"#";color:var(--ink-faint);margin-right:2px}
  .stack-cell .tag:hover{border-color:var(--accent);color:var(--accent)}

  /* numeric counters */
  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line);border:1px solid var(--line);margin-bottom:calc(var(--u)*8)}
  @media (max-width: 760px){.stats{grid-template-columns:repeat(2,1fr)}}
  .stat{background:var(--bg);padding:calc(var(--u)*2.5) calc(var(--u)*3);display:flex;flex-direction:column;gap:4px}
  .stat .sn{font-family:var(--fs-mono);font-weight:300;font-size:clamp(28px, 3.6vw, 44px);line-height:1;color:var(--accent);letter-spacing:-0.02em;font-variant-numeric:tabular-nums}
  .stat .sl{font-family:var(--fs-mono);font-size:10.5px;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink-faint)}

  /* ─────────────── CONTACT ─────────────── */
  .contact{padding-bottom:calc(var(--u) * 16)}
  .contact-card{position:relative;border:1px solid var(--line-strong);padding:clamp(28px, 5vw, 64px);overflow:hidden;background:
    repeating-linear-gradient(0deg, rgba(94,234,212,0.04) 0 1px, transparent 1px 32px),
    repeating-linear-gradient(90deg, rgba(94,234,212,0.04) 0 1px, transparent 1px 32px),
    linear-gradient(135deg, rgba(94,234,212,0.05), rgba(255,255,255,0.01))}
  .contact-card::after{content:"";position:absolute;top:0;right:0;width:200px;height:200px;background:radial-gradient(circle at top right, var(--accent-glow), transparent 70%);filter:blur(20px);pointer-events:none}
  .contact-card h2{font-family:var(--fs-mono);font-weight:500;font-size:clamp(32px, 5vw, 72px);line-height:1.0;letter-spacing:-0.04em;margin:0 0 20px;color:var(--ink);position:relative;text-transform:lowercase}
  .contact-card h2 .acc{color:var(--accent)}
  .contact-card p{color:var(--ink-dim);font-size:14px;max-width:54ch;margin:0 0 28px;position:relative}
  .contact-card p::before{content:"> ";color:var(--accent);opacity:.6}
  .contact-actions{display:flex;flex-wrap:wrap;gap:10px;position:relative}
  .btn{display:inline-flex;align-items:center;gap:10px;padding:12px 20px;font-family:var(--fs-mono);font-size:11.5px;letter-spacing:0.06em;text-transform:uppercase;transition:all .25s;border:1px solid transparent}
  .btn-primary{background:var(--accent);color:#04060a}
  .btn-primary:hover{background:var(--accent-2);color:#04060a;transform:translate(2px,-2px);box-shadow:-2px 2px 0 var(--accent)}
  .btn-ghost{border-color:var(--line-strong);color:var(--ink)}
  .btn-ghost:hover{border-color:var(--accent);color:var(--accent);transform:translate(2px,-2px);box-shadow:-2px 2px 0 var(--line-strong)}

  /* footer */
  .footer{padding:32px 0 48px;border-top:1px solid var(--line);font-family:var(--fs-mono);font-size:11px;color:var(--ink-faint);letter-spacing:0.04em}
  .footer-inner{display:flex;align-items:center;justify-content:space-between;gap:18px;flex-wrap:wrap}
  .footer .acc{color:var(--accent)}

  /* entrance reveals (scroll-driven) */
  .reveal{opacity:0;transform:translateY(14px);transition:opacity .7s ease, transform .7s cubic-bezier(.2,.8,.2,1)}
  .reveal.in{opacity:1;transform:translateY(0)}
  .reveal-1{transition-delay:.05s}
  .reveal-2{transition-delay:.12s}
  .reveal-3{transition-delay:.19s}

  @media (prefers-reduced-motion: reduce){
    .reveal{opacity:1;transform:none;transition:none}
    #cosmic-canvas{opacity:.4}
    .scanline,.scroll-cue .line,.status-pill .pulse::after{animation:none}
  }
</style>
</head>
<body>

<!-- Cosmic background stage -->
<div id="cosmic-stage" aria-hidden="true">
  <canvas id="cosmic-canvas"></canvas>
  <div class="scanline"></div>
  <div class="vignette"></div>
</div>

<!-- Scroll progress bar -->
<div class="scroll-progress"><div class="bar" id="scroll-bar"></div></div>

<!-- Hover preview thumbnail (editorial list) -->
<div class="work-preview" id="work-preview" aria-hidden="true">
  <div class="preview-frame"><span id="preview-frame-l">FRAME 01</span><span id="preview-frame-r">— —</span></div>
  <div class="preview-inner">
    <span class="preview-mark" id="preview-mark">⟁</span>
    <img class="preview-img" id="preview-img" alt="" />
    <div class="preview-scrim"></div>
  </div>
  <div class="preview-meta"><span class="pm-cat" id="preview-cat">CATEGORY</span><span class="pm-tag" id="preview-tag">VIEW →</span></div>
</div>

<!-- ─────────────── NAV ─────────────── -->
<nav class="nav">
  <div class="nav-inner">
    <a href="#top" class="brand"><span class="dot"></span><span>y_w_song.sh</span></a>
    <div class="nav-links">
      <a href="#work">work</a>
      <a href="#approach">approach</a>
      <a href="#stack">stack</a>
      <a href="#contact">contact</a>
    </div>
    <a class="nav-cta" href="mailto:youngwoo930@gmail.com">connect</a>
  </div>
</nav>

<!-- ─────────────── HERO ─────────────── -->
<section id="top" class="hero">
  <div class="wrap">
    <pre class="boot" id="boot" aria-hidden="true"></pre>

    <div class="hero-meta reveal">
      <span class="status-pill"><span class="pulse"></span><span>ai specialist · ignite · auckland · hybrid</span></span>
    </div>

    <h1 class="reveal reveal-1">
      young woo song<br>
      <span class="acc"><span class="glyph-shuffle" data-text="applied">applied</span></span> ai.
    </h1>

    <p class="hero-tag reveal reveal-2">
      <span class="prompt">$</span>
