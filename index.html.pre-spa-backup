    var cat  = document.getElementById("preview-cat");
    var tag  = document.getElementById("preview-tag");
    var fl   = document.getElementById("preview-frame-l");
    var fr   = document.getElementById("preview-frame-r");
    var activeRow = null;

    // Glyph mark stays visible behind the image until the thumbnail loads,
    // and is the fallback if a thumbnail is missing or fails to load.
    img.addEventListener("load", function(){ img.classList.add("loaded"); });
    img.addEventListener("error", function(){
      img.classList.remove("loaded");
      img.removeAttribute("src");
    });

    function setRow(row, i){
      if(row === activeRow) return;
      activeRow = row;
      mark.textContent = row.getAttribute("data-mark") || "⟁";
      cat.textContent = row.getAttribute("data-cat") || "";
      tag.textContent = (row.getAttribute("data-year") || "") + " · open →";
      fl.textContent = "FRAME " + String(i + 1).padStart(2, "0");
      fr.textContent = "● REC";
      var thumb = row.getAttribute("data-thumb");
      img.classList.remove("loaded");
      if(thumb){ img.src = thumb; }
      else { img.removeAttribute("src"); }
    }

    document.querySelectorAll(".work-row").forEach(function(row, i){
      row.addEventListener("mousemove", function(e){
        preview.style.left = e.clientX + "px";
        preview.style.top = e.clientY + "px";
        preview.classList.add("show");
        setRow(row, i);
      });
      row.addEventListener("mouseleave", function(){
        preview.classList.remove("show");
      });
    });
  })();
})();
</script>

</body>
</html>
